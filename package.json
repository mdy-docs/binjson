    "js",
    "wasm",
    "src",
    "include",
    "lib"
  ],
  "scripts": {
    "build:wasm": "./build-wasm.sh",
    "prepack": "npm run build:wasm"
  },
  "keywords": [
    "binary",
    "json",
    "encoding",
    "opfs",
    "storage",
    "objectid",
    "serialization"
  ],
