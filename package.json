{
  "name": "binjson",
  "version": "1.0.0",
  "description": "A compact binary encoding for JSON-like data (with MongoDB-style ObjectId/Pointer), plus OPFS-backed file support",
  "main": "js/binjson.js",
  "type": "module",
  "exports": {
    ".": "./js/binjson.js",
    "./wasm": "./wasm/binjson-wasm.js"
  },
  "files": [
    "js",
    "wasm",
    "src",
    "include",
    "lib",
    "bin"
  ],
  "bin": {
    "binjson": "bin/binjson.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build:wasm": "./build-wasm.sh",
    "prepack": "npm run build:wasm"
  },
  "keywords": [
    "binary",
    "json",
    "encoding",
    "opfs",
    "storage",
    "objectid",
    "serialization"
  ],
  "author": "",
  "license": "BSD-2-Clause",
  "devDependencies": {
    "node-opfs": "^1.2.0",
    "vitest": "^3.2.4"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fs-ext@2.1.1": true
  }
}
